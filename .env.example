# Chaîne de connexion PostgreSQL (Supabase, Neon ou serveur local).
# Rôle applicatif RESTREINT (notaria_app) : soumis à la Row-Level Security,
# jamais propriétaire du schéma, jamais superuser. C'est la connexion utilisée
# par l'application à l'exécution (next start).
DATABASE_URL=postgresql://notaria_app:motdepasse@localhost:5432/notaria

# Rôle PROPRIÉTAIRE du schéma (BYPASSRLS) : utilisé UNIQUEMENT par les migrations
# (npm run migrate / npm run db:migrate) et par tests/isolation.js pour créer les
# études fictives. Ne jamais utiliser cette connexion dans l'application.
# Si absent, la migration retombe sur DATABASE_URL — ce qui échouera dès que
# notaria_app est en place (RLS forcée, ce rôle n'a pas BYPASSRLS).
ADMIN_DATABASE_URL=postgresql://notaria_user:motdepasse@localhost:5432/notaria

# Secret JWT — générer une valeur longue et aléatoire (ex: openssl rand -hex 32)
JWT_SECRET=changez-moi-avant-toute-mise-en-ligne

# Rotation de clé JWT (optionnel) — si présent, prime sur JWT_SECRET. Permet de
# faire tourner le secret sans invalider les sessions en cours : ajouter la
# nouvelle clé, la déployer, puis basculer "active" dessus. Les anciennes clés
# restent acceptées en vérification tant qu'elles sont listées.
# JWT_SECRETS_JSON={"active":"2026-07","keys":{"2026-07":"<nouveau secret>","legacy":"<ancien secret>"}}

# Port HTTP interne de `next start` (proxé par Nginx). Défaut Next.js : 3000.
PORT=3000

# Charge les données de démonstration (30 actes/appels fictifs + 5 études de
# recette, mots de passe connus) au prochain `npm run migrate`. À NE JAMAIS
# activer sur une base contenant de vraies données clients.
# SEED_DEMO=1
