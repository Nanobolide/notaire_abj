# === DÉVELOPPEMENT LOCAL (SQLite) ===
# Ne pas définir DATABASE_URL — la base SQLite est créée dans data/notaria.db
DATABASE_PATH=data/notaria.db
JWT_SECRET=dev-secret-changez-moi

# === PRODUCTION RENDER (PostgreSQL) ===
# Injecté automatiquement par Render — ne pas mettre en local :
# DATABASE_URL=postgresql://...
# JWT_SECRET=...
# NODE_ENV=production
